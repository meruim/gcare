{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    { "source": "/terms/", "destination": "/terms", "permanent": true },
    { "source": "/privacy/", "destination": "/privacy", "permanent": true },
    { "source": "/faculty/", "destination": "/faculty", "permanent": true },
    { "source": "/docs/", "destination": "/docs", "permanent": true },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "jrmsu-gcare.com" }],
      "destination": "https://www.jrmsu-gcare.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
